### ============================================
### ПЕРЕМЕННЫЕ
### ============================================
@baseUrl = http://localhost:8000

### 1. Создание адреса доставки для пользователя
# @name createAddress
POST http://127.0.0.1:8000/api/users/addresses/
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzgzNDMwNTQ2LCJpYXQiOjE3ODM0Mjg3NDYsImp0aSI6IjVmZDdjN2Y3NGY4NjQyZjRhNzYyZThkZGI2ODFkYmJlIiwidXNlcl9pZCI6IjMifQ.A_Yfe5InrxsC8ry0oBVOy2ciysJ3TW0Lc3sGGqvpOkY
Content-Type: application/json

{
    "city": "Москва",
    "street": "Нагатинская",
    "house": "10",
    "apartment": "25"
}


### 2. Создание второго адреса
