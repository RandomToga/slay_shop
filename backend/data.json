{
    "model": "catalog.brand",
    "pk": 1,
    "fields": {
        "brand_name": "Shiseido",
        "brand_country": "Япония",
        "brand_description": "За вековой историей Shiseido стоит японский минимализм и глубочайшее уважение к природе кожи. Мы не боремся с несовершенствами — мы учим кожу самообновляться. Наши формулы вдохновлены традициями чайной церемонии и подкреплены технологией искусственного интеллекта. Это косметика, которая адаптируется к вашему индивидуальному ритму жизни, даря утреннюю свежесть, которая длится 24 часа."
    }
},
{
    "model": "catalog.brand",
    "pk": 2,
    "fields": {
        "brand_name": "La Roche-Posay",
        "brand_country": "Франция",
        "brand_description": "Это голос разума в мире бьюти-индустрии. Созданный при участии ведущих дерматологов, бренд использует целебную воду из термального источника, признанную самой чистой в Европе. Мы говорим «нет» агрессивным компонентам и «да» клинически доказанной эффективности. La Roche-Posay — это идеальный выбор для чувствительной кожи, которая устала от экспериментов. Это гарантия того, что ваша кожа будет не только красивой, но и по-настоящему здоровой, без покраснений и стянутости."
    }
},
{
    "model": "catalog.brand",
    "pk": 3,
    "fields": {
        "brand_name": "Dior",
        "brand_country": "Франция",
        "brand_description": "Dior — это не просто косметика, это высокая мода, воплощенная в текстурах и ароматах. Рожденный в сердце Парижа, бренд уже более 70 лет задает стандарты красоты, превращая ежедневный ритуал в мгновение истинного наслаждения. Используя экстракты редких цветов из собственного сада в Грасе, Dior дарит вашей коже сияние, достойное подиума."
    }
},
{
    "model": "catalog.brand",
    "pk": 4,
    "fields": {
        "brand_name": "Estee Lauder",
        "brand_country": "США",
        "brand_description": "Estée Lauder — это симбиоз передовых биотехнологий и безошибочного вкуса. Мы верим, что возраст — это всего лишь цифра, поэтому создаем формулы, которые запускают регенерацию кожи на клеточном уровне. Это косметика для женщин, которые живут на полной скорости, но выглядят так, будто время над ними не властно. Сияй ярче с Estée Lauder."
    }
},
{
    "model": "catalog.brand",
    "pk": 5,
    "fields": {
        "brand_name": "LUSH",
        "brand_country": "Великобритания",
        "brand_description": "LUSH — это яркий, шумный и безумно ароматный протест против скучной косметики. Мы создаем продукцию вручную из свежайших фруктов, овощей и эфирных масел, совсем как на кухне. Никакой жестокости, никаких пластиковых упаковок там, где это возможно, только честность и взрыв эмоций. Наши бомбочки для ванны превратят ритуал купания в красочное шоу, а маски для лица — в настоящее спа-наслаждение."
    }
},
{
